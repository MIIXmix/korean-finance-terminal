# Core
# Leave APP_SECRET blank — a strong secret auto-generates to .data/secret.key on first run.
APP_SECRET=
DATABASE_PATH=.data/terminal.db
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
TOKEN_TTL_MINUTES=240

# Optional AI fallback. Normally leave blank and enter your key in-app (onboarding/Settings).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Filings
SEC_USER_AGENT=KoreanFinanceTerminal/0.1 your-email@example.com
DART_API_KEY=

# Trading safety
LIVE_TRADING_ENABLED=false

# Optional broker credentials. Store user keys through the app only for local use.
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
IBKR_BASE_URL=https://localhost:5000/v1/api
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=
